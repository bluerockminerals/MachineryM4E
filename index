var currentLang="en",activePage="home",currentFilter="all";

function showPage(page){
  document.querySelectorAll(".page").forEach(function(p){p.classList.remove("active");});
  document.getElementById("page-"+page).classList.add("active");
  activePage=page;
  window.scrollTo({top:0,behavior:"smooth"});
  if(page==="inventory") renderInventory();
}

function renderInventory(filter){
  if(filter!==undefined) currentFilter=filter;
  var grid=document.getElementById("invGrid");
  var t=T[currentLang];
  var filtered=currentFilter==="all"?PRODUCTS:PRODUCTS.filter(function(p){return p.cat===currentFilter;});
  document.getElementById("visibleCount").textContent=filtered.length;
  grid.innerHTML=filtered.map(function(p){
    var mainImg=p.imgs&&p.imgs.length?'<img src="'+p.imgs[0]+'" alt="'+p.title+'" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display=\'none\';this.nextSibling.style.display=\'flex\'">'+(CAT_ICONS[p.cat]||CAT_ICONS.loader):'<div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%">'+(CAT_ICONS[p.cat]||CAT_ICONS.loader)+'</div>';
    var catLabel=p.cat.charAt(0).toUpperCase()+p.cat.slice(1);
    return '<div class="product-card" onclick="showDetail('+p.id+')">'+
      '<div class="product-img">'+mainImg+'<span class="product-tag">'+p.tag+'</span></div>'+
      '<div class="product-info"><h4>'+p.title+'</h4>'+
      '<div class="product-meta">'+p.brand+' · '+p.year+' · '+catLabel+'</div>'+
      '<div class="product-cta"><button class="inquire-btn">'+t.inquire+' <span class="inquire-arrow">&#8594;</span></button></div>'+
      '</div></div>';
  }).join("");
  document.querySelectorAll(".filter-btn").forEach(function(b){
    b.classList.toggle("active",b.dataset.cat===currentFilter);
  });
}

document.getElementById("page-inventory").addEventListener("click",function(e){
  var btn=e.target.closest(".filter-btn");
  if(btn) renderInventory(btn.dataset.cat);
});

function showDetail(id){
  var p=PRODUCTS.find(function(x){return x.id===id;});
  if(!p) return;
  document.getElementById("detailTag").textContent=p.tag;
  document.getElementById("detailBrand").textContent=p.brand+" · "+p.year;
  document.getElementById("detailTitle").textContent=p.title;
  document.getElementById("detailDesc").textContent=p.desc;

  // Build image gallery
  var imgs=p.imgs&&p.imgs.length?p.imgs:[];
  var mainSrc=imgs.length?imgs[0]:"";
  var imgBox=document.getElementById("detailImg");
  var galleryHTML='';
  if(mainSrc){
    galleryHTML='<img id="detailMainImg" src="'+mainSrc+'" alt="'+p.title+'" style="width:100%;height:100%;object-fit:cover;display:block;">';
  } else {
    galleryHTML=(CAT_ICONS[p.cat]||CAT_ICONS.loader);
  }
  galleryHTML+='<span class="detail-tag">'+p.tag+'</span>';
  imgBox.innerHTML=galleryHTML;

  // Thumbnails
  var thumbsEl=document.getElementById("detailThumbs");
  if(imgs.length>1){
    thumbsEl.style.display="flex";
    thumbsEl.innerHTML=imgs.map(function(src,i){
      return '<img src="'+src+'" onclick="switchDetailImg(\''+src+'\')" style="width:70px;height:52px;object-fit:cover;cursor:pointer;border:2px solid '+(i===0?'var(--gold)':'var(--steel)')+';flex-shrink:0;transition:border-color .2s;" onmouseover="this.style.borderColor=\'var(--gold)\'" onmouseout="this.style.borderColor=this.src.includes(document.getElementById(\'detailMainImg\')&&document.getElementById(\'detailMainImg\').src)?\'var(--gold)\':\'var(--steel)\'">';
    }).join("");
  } else {
    thumbsEl.style.display="none";
    thumbsEl.innerHTML="";
  }

  var specsEl=document.getElementById("detailSpecs");
  specsEl.innerHTML=Object.entries(p.specs).map(function(e){
    return '<div class="spec-item"><div class="spec-label">'+e[0]+'</div><div class="spec-value">'+e[1]+'</div></div>';
  }).join("");
  showPage("detail");
}

function switchDetailImg(src){
  var main=document.getElementById("detailMainImg");
  if(main) main.src=src;
  document.querySelectorAll("#detailThumbs img").forEach(function(th){
    th.style.borderColor=th.src.endsWith(src.split("/").pop())?"var(--gold)":"var(--steel)";
  });
}

function showNotif(){
  var n=document.getElementById("notif");
  n.classList.add("show");
  setTimeout(function(){n.classList.remove("show");},3500);
}
document.getElementById("quoteBtn").addEventListener("click",showNotif);
document.getElementById("formSubmit").addEventListener("click",showNotif);

function applyLang(lang){
  var t=T[lang];
  if(!t) return;
  currentLang=lang;
  document.documentElement.lang=lang;
  document.querySelectorAll("[data-i18n]").forEach(function(el){
    var k=el.dataset.i18n;
    if(t[k]!==undefined) el.innerHTML=t[k];
  });
  document.querySelectorAll("[data-i18n-ph]").forEach(function(el){
    var k=el.dataset.i18nPh;
    if(t[k]!==undefined) el.placeholder=t[k];
  });
  if(activePage==="inventory") renderInventory();
}

