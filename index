function renderInvSlider(){
  var track = document.getElementById("invSliderTrack");
  if (!track) { console.log("invSliderTrack not found"); return; }
  var t = T[currentLang] || T["en"];
  var html = "";
  for (var i = 0; i < PRODUCTS.length; i++) {
    var p = PRODUCTS[i];
    var mainImg = (p.imgs && p.imgs.length > 0) ? p.imgs[0] : "";
    var brandShort = p.brand.split(" ")[0];
    var shortDesc = p.desc ? p.desc.substring(0, 88) + (p.desc.length > 88 ? "..." : "") : "";
    var imgHtml = mainImg
      ? '<img class="inv-slide-img" src="' + mainImg + '" alt="' + p.title + '">'
      : '<div class="inv-slide-placeholder"><svg viewBox="0 0 64 64"><path d="M8 40h48v4H8zm4-16h8v16h-8zm12 8h28v8H24z"/></svg></div>';
    html += '<div class="inv-slide-card" onclick="showDetail(' + p.id + ')">'
      + '<div class="inv-slide-img-wrap">' + imgHtml
      + '<div class="inv-slide-brand-badge">' + brandShort + '</div></div>'
      + '<div class="inv-slide-body">'
      + '<div class="inv-slide-title">' + p.title + '</div>'
      + '<div class="inv-slide-desc">' + shortDesc + '</div>'
      + '<button class="inv-slide-cta">' + (t.detail_quote || "Request Quote") + '</button>'
      + '</div></div>';
  }
  track.innerHTML = html;
}

function slideInv(dir){
  var track=document.getElementById("invSliderTrack");
  if(track) track.scrollBy({left:dir*580,behavior:"smooth"});
}

// Ensure slider renders after DOM is ready
document.addEventListener("DOMContentLoaded", function() {
  renderInvSlider();
});
// Also patch showPage so slider re-renders when going back to home
var _spOrig = showPage;
showPage = function(pg) {
  _spOrig(pg);
  if (pg === "home") setTimeout(renderInvSlider, 30);
};
// Run now too in case DOMContentLoaded already fired
