<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Machinery 4 Export | Heavy Equipment Global Solutions</title>
<link rel="icon" type="image/x-icon" href="favicon.ico">
<link rel="shortcut icon" href="favicon.ico">
<link rel="apple-touch-icon" href="icono-m4e.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--gold:#C8922A;--gold-light:#E8B84B;--gold-dark:#8A611A;--black:#0A0A0A;--dark:#111214;--dark2:#1A1C20;--dark3:#242628;--steel:#2C2F35;--muted:#6B7280;--white:#F5F4F0}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:"Barlow",sans-serif;background:var(--black);color:var(--white);overflow-x:hidden}
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.8rem 4rem;background:#ffffff;border-bottom:3px solid var(--gold);transition:box-shadow .3s;box-shadow:0 2px 16px rgba(0,0,0,.15)}
.logo{display:flex;align-items:center;cursor:pointer;background:none;border:none;padding:0;text-decoration:none}
.logo img{height:44px;width:auto;display:block;transition:opacity .2s}
.logo:hover img{opacity:.85}
.logo-icon{display:none}
footer .logo img{height:34px;filter:brightness(0) invert(1)}
.nav-links{display:flex;gap:2rem;list-style:none;align-items:center}
.nav-link-btn{font-size:.85rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#1a1a1a;background:none;border:none;cursor:pointer;font-family:"Barlow",sans-serif;transition:color .2s}
.nav-link-btn:hover{color:var(--gold)}
.nav-cta{background:var(--gold);color:var(--black);padding:.55rem 1.4rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);transition:background .2s;border:none;cursor:pointer;font-family:"Barlow Condensed",sans-serif;font-size:.85rem}
.nav-cta:hover{background:var(--gold-light)}
.lang-wrapper{position:relative}
.lang-btn{display:flex;align-items:center;gap:.4rem;background:transparent;border:1px solid #ccc;color:#555;padding:.42rem .85rem;font-family:"Barlow Condensed",sans-serif;font-size:.82rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;transition:all .2s;clip-path:polygon(5px 0%,100% 0%,calc(100% - 5px) 100%,0% 100%)}
.lang-btn:hover,.lang-btn.active{border-color:var(--gold);color:var(--gold)}
.lang-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0}
.lang-dropdown{position:absolute;top:calc(100% + 10px);right:0;background:var(--dark2);border:1px solid var(--steel);min-width:155px;z-index:300;display:none;flex-direction:column}
.lang-dropdown.open{display:flex}
.lang-option{display:flex;align-items:center;gap:.6rem;padding:.6rem 1rem;font-family:"Barlow Condensed",sans-serif;font-size:.85rem;font-weight:600;letter-spacing:.06em;color:var(--muted);cursor:pointer;border:none;background:transparent;text-align:left;width:100%;transition:all .15s;border-bottom:1px solid rgba(44,47,53,.6)}
.lang-option:last-child{border-bottom:none}
.lang-option:hover{background:var(--dark3);color:var(--white)}
.lang-option.selected{color:var(--gold);background:rgba(200,146,42,.07)}
.trans-bar{position:fixed;top:0;left:0;right:0;height:3px;background:var(--gold);z-index:999;transform-origin:left;transform:scaleX(0);transition:transform .4s ease}
.trans-bar.run{transform:scaleX(.85)}
.trans-bar.done{transform:scaleX(1);transition:transform .1s ease}
.page{display:none;min-height:100vh;padding-top:72px}
.page.active{display:block}
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;position:relative;overflow:hidden;padding:0 4rem 5rem}
.hero-bg{position:absolute;inset:0;background:linear-gradient(to right,rgba(10,10,10,.98) 40%,rgba(10,10,10,.5) 100%),url("https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?w=1800&q=80") center/cover no-repeat}
.hero-bg::after{content:"";position:absolute;inset:0;background:linear-gradient(to top,var(--black) 0%,transparent 40%)}
.hero-label{position:relative;z-index:2;font-family:"Barlow Condensed",sans-serif;font-size:.8rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.75rem;margin-bottom:1.5rem}
.hero-label::before{content:"";display:block;width:32px;height:2px;background:var(--gold)}
.hero h1{position:relative;z-index:2;font-family:"Barlow Condensed",sans-serif;font-size:clamp(3.5rem,8vw,7rem);font-weight:900;line-height:.92;text-transform:uppercase;margin-bottom:1.5rem;max-width:700px}
.hero h1 em{font-style:normal;color:var(--gold);display:block}
.hero-sub{position:relative;z-index:2;font-size:1.05rem;color:rgba(245,244,240,.6);max-width:480px;line-height:1.65;margin-bottom:2.5rem}
.hero-actions{position:relative;z-index:2;display:flex;gap:1rem;align-items:center}
.btn-primary{background:var(--gold);color:var(--black);padding:.9rem 2.2rem;font-family:"Barlow Condensed",sans-serif;font-size:1rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);transition:background .2s,transform .15s;border:none;cursor:pointer;text-decoration:none;display:inline-block}
.btn-primary:hover{background:var(--gold-light);transform:translateY(-2px)}
.btn-ghost{color:var(--white);font-family:"Barlow Condensed",sans-serif;font-size:1rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;display:flex;align-items:center;gap:.5rem;padding-bottom:2px;transition:color .2s,border-color .2s;background:none;border:none;border-bottom:1px solid rgba(245,244,240,.3);cursor:pointer}
.btn-ghost:hover{color:var(--gold);border-color:var(--gold)}
.hero-stats{position:absolute;bottom:5rem;right:4rem;z-index:2;display:flex;flex-direction:column;gap:1.2rem}
.stat-item{text-align:right}
.stat-num{font-family:"Barlow Condensed",sans-serif;font-size:2.4rem;font-weight:900;color:var(--gold);line-height:1}
.stat-label{font-size:.7rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--muted)}
.scroll-indicator{position:absolute;bottom:2.5rem;left:4rem;z-index:2;display:flex;align-items:center;gap:.75rem}
.scroll-line{width:40px;height:1px;background:rgba(245,244,240,.3);position:relative;overflow:hidden}
.scroll-line::after{content:"";position:absolute;top:0;left:-100%;width:100%;height:100%;background:var(--gold);animation:scrollLine 2s ease-in-out infinite}
@keyframes scrollLine{from{left:-100%}to{left:100%}}
.scroll-text{font-size:.68rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,244,240,.4)}
.ticker{background:var(--gold);padding:.65rem 0;overflow:hidden;white-space:nowrap}
.ticker-inner{display:inline-flex;gap:3rem;animation:ticker 25s linear infinite}
.ticker span{font-family:"Barlow Condensed",sans-serif;font-size:.85rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--black)}
.ticker-dot{color:rgba(10,10,10,.4) !important}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.section-label{font-family:"Barlow Condensed",sans-serif;font-size:.75rem;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.75rem;margin-bottom:1.2rem}
.section-label::before{content:"";width:24px;height:2px;background:var(--gold)}
.section-title{font-family:"Barlow Condensed",sans-serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:900;text-transform:uppercase;line-height:.95}
.line-divider{height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);opacity:.3}
.about-wrap{background:var(--dark);display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;padding:6rem 4rem}
.about-img{position:relative}
.about-img img{width:100%;height:480px;object-fit:cover;display:block;filter:grayscale(20%)}
.about-img-frame{position:absolute;top:-20px;right:-20px;width:100%;height:100%;border:2px solid var(--gold);z-index:-1}
.about-badge{position:absolute;bottom:-20px;left:-20px;background:var(--gold);padding:1.2rem 1.5rem;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%)}
.about-badge-num{font-family:"Barlow Condensed",sans-serif;font-size:2.2rem;font-weight:900;color:var(--black);line-height:1}
.about-badge-label{font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(10,10,10,.65)}
.about-text p{color:rgba(245,244,240,.65);line-height:1.75;margin-bottom:1.5rem;font-size:1.05rem}
.about-text .section-title{margin-bottom:1.5rem}
.about-features{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:2rem}
.feature-item{display:flex;align-items:flex-start;gap:.75rem;padding:1rem;background:var(--dark2);border-left:3px solid var(--gold)}
.feature-item svg{flex-shrink:0;width:20px;height:20px;fill:var(--gold);margin-top:2px}
.feature-item strong{display:block;font-family:"Barlow Condensed",sans-serif;font-size:.9rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--white);margin-bottom:.2rem}
.feature-item span{font-size:.82rem;color:var(--muted)}
.services-wrap{background:var(--black);padding:6rem 4rem}
.services-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3.5rem}
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--steel)}
.service-card{background:var(--dark);padding:2.5rem 2rem;position:relative;overflow:hidden;transition:background .3s;cursor:default}
.service-card::before{content:"";position:absolute;bottom:0;left:0;width:100%;height:3px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.service-card:hover{background:var(--dark2)}
.service-card:hover::before{transform:scaleX(1)}
.service-icon{width:52px;height:52px;background:rgba(200,146,42,.12);display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%)}
.service-icon svg{width:26px;height:26px;fill:var(--gold)}
.service-num{font-family:"Barlow Condensed",sans-serif;font-size:4rem;font-weight:900;color:rgba(200,146,42,.06);position:absolute;top:1rem;right:1.5rem;line-height:1;pointer-events:none}
.service-card h3{font-family:"Barlow Condensed",sans-serif;font-size:1.2rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.75rem}
.service-card p{font-size:.88rem;color:var(--muted);line-height:1.65}
.service-detail{margin-top:1rem;font-size:.78rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--gold-dark)}
.inv-page-wrap{background:var(--dark);min-height:100vh;padding:3rem 4rem 6rem}
.inv-page-header{margin-bottom:2rem;padding-top:1rem}
.inv-page-header .section-title{margin-bottom:.75rem}
.inv-toolbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem}
.inv-count{font-family:"Barlow Condensed",sans-serif;font-size:.85rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted)}
.inv-count span{color:var(--gold)}
.filter-row{display:flex;gap:.5rem;flex-wrap:wrap}
.filter-btn{font-family:"Barlow Condensed",sans-serif;font-size:.8rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:.42rem 1rem;background:transparent;border:1px solid var(--steel);color:var(--muted);cursor:pointer;transition:all .2s}
.filter-btn.active,.filter-btn:hover{background:var(--gold);color:var(--black);border-color:var(--gold)}
.inv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.product-card{background:var(--dark2);overflow:hidden;transition:transform .25s;cursor:pointer}
.product-card:hover{transform:translateY(-4px)}
.product-img{width:100%;height:200px;background:var(--steel);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.product-img svg{width:60px;height:60px;fill:rgba(200,146,42,.2)}
.product-tag{position:absolute;top:1rem;left:1rem;background:var(--gold);font-family:"Barlow Condensed",sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--black);padding:.2rem .65rem;clip-path:polygon(4px 0%,100% 0%,calc(100% - 4px) 100%,0% 100%)}
.product-info{padding:1.4rem;border-top:1px solid var(--steel)}
.product-info h4{font-family:"Barlow Condensed",sans-serif;font-size:1.05rem;font-weight:800;text-transform:uppercase;letter-spacing:.03em;margin-bottom:.4rem;line-height:1.2}
.product-meta{font-size:.78rem;color:var(--muted);display:flex;align-items:center;gap:.5rem}
.product-meta::before{content:"";width:8px;height:8px;background:var(--gold);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);flex-shrink:0}
.product-cta{margin-top:1rem}
.inquire-btn{font-family:"Barlow Condensed",sans-serif;font-size:.8rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.35rem;background:none;border:none;border-bottom:1px solid transparent;cursor:pointer;transition:border-color .2s;padding:0}
.inquire-btn:hover{border-color:var(--gold)}
.inquire-arrow{transition:transform .2s}
.product-card:hover .inquire-arrow{transform:translateX(3px)}
.page-hero{height:320px;display:flex;align-items:flex-end;padding:3rem 4rem;position:relative;overflow:hidden}
.page-hero-bg{position:absolute;inset:0;background:linear-gradient(to right,rgba(10,10,10,.97) 50%,rgba(10,10,10,.6) 100%),url("https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=1400&q=70") center/cover no-repeat}
.page-hero-bg::after{content:"";position:absolute;inset:0;background:linear-gradient(to top,var(--black) 0%,transparent 50%)}
.page-hero-content{position:relative;z-index:2}
.page-hero-content .section-label{margin-bottom:.75rem}
.page-hero-content .section-title{font-size:clamp(2rem,5vw,3.5rem)}
.detail-wrap{background:var(--dark);min-height:calc(100vh - 72px);padding:3rem 4rem 6rem}
.detail-back{font-family:"Barlow Condensed",sans-serif;font-size:.82rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:.5rem;margin-bottom:2rem;transition:color .2s;padding:0}
.detail-back:hover{color:var(--gold)}
.detail-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:4rem;align-items:start}
.detail-img-box{background:var(--dark2);height:420px;display:flex;align-items:center;justify-content:center;position:relative;border:1px solid var(--steel)}
.detail-img-box svg{width:120px;height:120px;fill:rgba(200,146,42,.18)}
.detail-tag{position:absolute;top:1.2rem;left:1.2rem;background:var(--gold);font-family:"Barlow Condensed",sans-serif;font-size:.75rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--black);padding:.25rem .8rem;clip-path:polygon(4px 0%,100% 0%,calc(100% - 4px) 100%,0% 100%)}
.detail-brand{font-family:"Barlow Condensed",sans-serif;font-size:.8rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);margin-bottom:.75rem;display:flex;align-items:center;gap:.5rem}
.detail-brand::before{content:"";width:20px;height:2px;background:var(--gold)}
.detail-title{font-family:"Barlow Condensed",sans-serif;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:900;text-transform:uppercase;line-height:1.05;margin-bottom:1.5rem}
.detail-specs{display:grid;grid-template-columns:1fr 1fr;gap:.75rem 1.5rem;margin-bottom:2rem}
.spec-label{font-size:.68rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:.2rem}
.spec-value{font-size:.95rem;font-weight:600;color:var(--white)}
.detail-desc{font-size:.95rem;color:rgba(245,244,240,.6);line-height:1.75;margin-bottom:2rem;padding-top:1.5rem;border-top:1px solid var(--steel)}
.detail-actions{display:flex;gap:1rem}
.contact-wrap{background:var(--black);display:grid;grid-template-columns:1fr 1fr;min-height:calc(100vh - 72px)}
.contact-left{padding:6rem 4rem;background:var(--gold);position:relative;overflow:hidden}
.contact-left::before{content:"";position:absolute;bottom:-60px;right:-60px;width:300px;height:300px;background:rgba(10,10,10,.08);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%)}
.contact-left .section-label{color:var(--black)}
.contact-left .section-label::before{background:var(--black)}
.contact-left .section-title{color:var(--black);margin-bottom:2rem}
.contact-info-item{display:flex;gap:1rem;margin-bottom:1.8rem;align-items:flex-start}
.contact-icon{width:40px;height:40px;background:rgba(10,10,10,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%)}
.contact-icon svg{width:18px;height:18px;fill:none;stroke:var(--black);stroke-width:2}
.contact-info-label{font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(10,10,10,.5);margin-bottom:.2rem}
.contact-info-value{font-size:.95rem;font-weight:600;color:var(--black);line-height:1.4}
.contact-right{padding:6rem 4rem;background:var(--dark)}
.contact-right h3{font-family:"Barlow Condensed",sans-serif;font-size:1.5rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;margin-bottom:2rem}
.form-group{margin-bottom:1.5rem}
.form-label{display:block;font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:.5rem}
.form-input{width:100%;background:var(--dark2);border:1px solid var(--steel);color:var(--white);padding:.85rem 1rem;font-family:"Barlow",sans-serif;font-size:.95rem;outline:none;transition:border-color .2s}
.form-input:focus{border-color:var(--gold)}
.form-input::placeholder{color:var(--muted)}
textarea.form-input{resize:none;height:120px}
.form-submit{width:100%;background:var(--gold);color:var(--black);border:none;padding:1rem;font-family:"Barlow Condensed",sans-serif;font-size:1rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase;cursor:pointer;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);transition:background .2s}
.form-submit:hover{background:var(--gold-light)}
.reach-section{background:var(--dark2);padding:5rem 4rem;position:relative;overflow:hidden}
.reach-section::before{content:"GLOBAL";position:absolute;font-family:"Barlow Condensed",sans-serif;font-size:18rem;font-weight:900;color:rgba(200,146,42,.03);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;white-space:nowrap}
.reach-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;position:relative;z-index:1}
.reach-map svg{width:100%;height:auto}
.reach-text .section-title{margin-bottom:1.5rem}
.reach-text p{font-size:1rem;color:rgba(245,244,240,.6);line-height:1.75;margin-bottom:1.5rem}
.reach-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;margin-top:1.5rem}
.reach-stat{padding:1.2rem;background:var(--dark);border-top:2px solid var(--gold)}
.reach-stat-num{font-family:"Barlow Condensed",sans-serif;font-size:2rem;font-weight:900;color:var(--gold);line-height:1}
.reach-stat-label{font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:.3rem}
footer{background:var(--black);border-top:1px solid var(--steel);padding:2rem 4rem;display:flex;justify-content:space-between;align-items:center}
footer .logo{font-size:1.2rem}
.footer-copy{font-size:.78rem;color:var(--muted);text-align:center}
.footer-links{display:flex;gap:2rem;list-style:none}
.footer-link-btn{font-size:.78rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);background:none;border:none;cursor:pointer;font-family:"Barlow",sans-serif;transition:color .2s}
.footer-link-btn:hover{color:var(--gold)}
.notif{position:fixed;bottom:2rem;right:2rem;z-index:500;background:var(--dark2);border:1px solid var(--gold);border-left:4px solid var(--gold);padding:1rem 1.5rem;max-width:340px;transform:translateX(120%);transition:transform .35s ease;display:flex;align-items:center;gap:.75rem}
.notif.show{transform:translateX(0)}
.notif svg{width:20px;height:20px;fill:var(--gold);flex-shrink:0}
.notif-text strong{display:block;font-family:"Barlow Condensed",sans-serif;font-size:1rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.2rem}
.notif-text span{font-size:.85rem;color:rgba(245,244,240,.7)}

.hero-logo{position:absolute;top:50%;left:55%;transform:translate(-50%,-50%);z-index:2;pointer-events:none}
.hero-logo img{width:min(480px,48vw);height:auto;opacity:1;mix-blend-mode:screen;filter:drop-shadow(0 0 30px rgba(255,255,255,0.8)) drop-shadow(0 0 60px rgba(255,255,255,0.4)) brightness(1.1)}
.inv-slider-section{background:var(--dark);padding:5rem 0 4rem;overflow:hidden}
.inv-slider-header{padding:0 4rem;margin-bottom:3rem;display:flex;flex-direction:column;gap:1.2rem}
.inv-slider-header-row{display:flex;justify-content:space-between;align-items:center}
